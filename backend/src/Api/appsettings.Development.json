{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=FinancialOCR.Dev;Trusted_Connection=true;TrustServerCertificate=true;"
  },
  "DocumentUpload": {
    "RootFolder": "App_Data/uploads",
    "MaxFileSizeMb": 10
  },
  "Ocr": {
    "EnableNativePdfText": true,
    "EnableTesseract": true,
    "TesseractDataPath": "App_Data/tessdata",
    "DefaultLanguage": "eng+fra",
    "EnglishLanguage": "eng",
    "FrenchLanguage": "fra",
    "BilingualLanguage": "eng+fra",
    "VisionOcr": {
      "PreferredProvider": "GeminiFlashLite",
      "FallbackEnabled": true,
      "UseForScannedPdf": true,
      "UseForLowConfidenceResults": true,
      "UseForValidationFailures": true,
      "MinPrimaryOcrConfidence": 0.75,
      "MinRawTextLength": 80,
      "GeminiFlashLite": {
        "Enabled": true,
        "ProviderName": "GoogleGemini",
        "Model": "CONFIGURE_ACTUAL_MODEL_ID_HERE",
        "ApiKey": "",
        "Endpoint": "",
        "TimeoutSeconds": 60,
        "MaxRetries": 2
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
