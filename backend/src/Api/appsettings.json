{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=FinancialOCR;Trusted_Connection=true;"
  },
  "DocumentUpload": {
    "RootFolder": "App_Data/uploads",
    "MaxFileSizeMb": 10
  },
  "Ocr": {
    "EnableNativePdfText": true,
    "EnableTesseract": false,
    "PreferVisionFallback": true,
    "PreferredVisionProvider": "Gemini",
    "GeminiModelName": "",
    "GeminiApiKey": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "FinancialOCR": "Information"
    }
  },
  "AllowedHosts": "*"
}
