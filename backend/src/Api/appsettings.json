{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=FinancialOCR;Trusted_Connection=true;"
  },
  "DocumentUpload": {
    "RootFolder": "App_Data/uploads",
    "MaxFileSizeMb": 10
  },
  "Ocr": {
    "EnableNativePdfText": true,
    "EnableTesseract": true,
    "TesseractDataPath": "App_Data/tessdata",
    "DefaultLanguage": "eng+fra",
    "EnglishLanguage": "eng",
    "FrenchLanguage": "fra",
    "BilingualLanguage": "eng+fra",
    "PreferredFallbackProvider": "GeminiFlashLite",
    "EnableFallbackOnLowConfidence": true,
    "EnableFallbackOnValidationFailure": true,
    "MinimumOcrConfidence": 0.75,
    "MinimumRawTextLength": 80,
    "AutoCompleteConfidenceThreshold": 0.75,
    "VisionOcr": {
      "PreferredProvider": "GeminiFlashLite",
      "FallbackEnabled": true,
      "GeminiFlashLite": {
        "Enabled": true,
        "ProviderName": "GoogleGemini",
        "Model": "CONFIGURE_ACTUAL_MODEL_ID_HERE",
        "ApiKey": "",
        "Endpoint": "",
        "TimeoutSeconds": 60,
        "MaxRetries": 2
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "FinancialOCR": "Information"
    }
  },
  "AllowedHosts": "*"
}
